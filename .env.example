# Backend
APP_ENV=development
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# LLM
LLM_PROVIDER=openai
OPENAI_API_KEY=replace_with_your_api_key
OPENAI_MODEL=gpt-4o-mini

# Voicebox
VOICEBOX_BASE_URL=http://127.0.0.1:17493

# Paths
SKILLS_CONFIG_PATH=config/skills.json
VOICES_CONFIG_PATH=config/voices.json
AUDIO_CACHE_DIR=audio_cache